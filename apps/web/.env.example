# PlanPal — environment variables.
#
# Copy this file to `.env.local` and fill in real values. Never commit `.env.local`.
# NEXT_PUBLIC_* values are exposed to the browser (Firebase web config is public).

# --- Firebase web (client) config ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server) credentials — keep secret, server-only ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key on one line with literal \n for newlines, wrapped in quotes:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# --- OpenAI (server-only, plan-grounded assistant — MVP-7) ---
# Required to enable the assistant. NEVER expose as NEXT_PUBLIC_*; keep server-side.
OPENAI_API_KEY=
# Optional. Defaults to the recommended low-cost structured-output model
# (verify the exact id against OpenAI's available API models). e.g. gpt-5.4-mini
OPENAI_MODEL=
